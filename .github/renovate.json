{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>ModernMavericks/shared-cmake"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^UPSTREAM_VERSION$"],
      "matchStrings": ["^(?<currentValue>.+?)\\s*$"],
      "depNameTemplate": "macports/macports-legacy-support",
      "packageNameTemplate": "macports/macports-legacy-support",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
