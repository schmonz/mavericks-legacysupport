#!/bin/sh
# Load the daily update-check agent, then borrow the system's own framework icon for the updater.
#
# The agent-load logic is NOT written here: stage_updater.sh renders it beside this script as
# agent-load.sh, so every ModernMavericks product loads its agent the same way.
AGENT_LOAD="$(dirname "$0")/agent-load.sh"
if [ -f "$AGENT_LOAD" ]; then
    . "$AGENT_LOAD"
fi

# Icon: we ship a neutral placeholder and swap in Mac OS X's own framework icon at install time --
# the same rule the rest of the line follows, so no Apple artwork travels in our payload. A machine
# missing every candidate just keeps the placeholder; that is why this is best-effort.
UPD_ICON="/Library/Application Support/ModernMavericks/LegacySupportUpdater.app/Contents/Resources/macports-legacy-support-updater.icns"
CORETYPES="/System/Library/CoreServices/CoreTypes.bundle/Contents/Resources"
if [ -f "$UPD_ICON" ]; then
    for candidate in \
        "$CORETYPES/GenericFrameworkIcon.icns" \
        "$CORETYPES/LibraryFolderIcon.icns" \
        "$CORETYPES/KEXT.icns"; do
        if [ -f "$candidate" ]; then
            cp "$candidate" "$UPD_ICON" 2>/dev/null || true
            break
        fi
    done
fi

exit 0
